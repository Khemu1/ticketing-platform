{
  "name": "@ticketing/shared",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typeorm": "cross-env NODE_ENV=development typeorm-ts-node-commonjs -d src/config/db/data-source.ts",
    "typeorm:prod": "cross-env NODE_ENV=production typeorm -d dist/src/config/db/data-source.prod.js",
    "migration:run:prod": "npm run typeorm:prod -- migration:run",
    "migration:run:dev": "npm run typeorm -- migration:run",
    "migration:revert:prod": "npm run typeorm:prod -- migration:revert",
    "migration:revert:dev": "npm run typeorm -- migration:revert",
    "migration:generate:prod": "cross-env NODE_ENV=production typeorm-ts-node-commonjs -d src/config/db/data-source.prod.ts migration:generate src/migrations/initial-schema",
    "migration:generate:dev": "cross-env NODE_ENV=development npm run typeorm -- migration:generate src/migrations/"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.1",
    "@types/express": "^5.0.6",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.26",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/typeorm": "^11.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}